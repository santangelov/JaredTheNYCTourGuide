<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation debug="true" strict="false" explicit="true" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" />
  </system.web>

  <system.codedom>
    <compilers>
      <compiler language="c#;cs;csharp"
                extension=".cs"
                type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.CSharpCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                warningLevel="4"
                compilerOptions="/langversion:6 /nowarn:1659;1699;1701" />
      <compiler language="vb;vbs;visualbasic;vbscript"
                extension=".vb"
                type="Microsoft.CodeDom.Providers.DotNetCompilerPlatform.VBCodeProvider, Microsoft.CodeDom.Providers.DotNetCompilerPlatform, Version=2.0.1.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"
                warningLevel="4"
                compilerOptions="/langversion:14 /nowarn:41008 /define:_MYTYPE=&quot;Web&quot; /optionInfer+" />
    </compilers>
  </system.codedom>

  <system.webServer>
    <rewrite>
      <rewriteMaps>
        <rewriteMap name="LegacyRootPageTargets">
          <add key="index.htm" value="/" />
          <add key="contact.htm" value="/contact.htm" />
          <add key="aboutJared.htm" value="/aboutJared.htm" />
          <add key="testimonials.htm" value="/testimonials.htm" />
          <add key="faqs.htm" value="/faqs.htm" />
          <add key="custom_tours.htm" value="/custom_tours.htm" />
          <add key="destinations.htm" value="/destinations.htm" />
          <add key="tourBooking.aspx" value="/tourBooking.aspx" />
          <add key="TourBooking.aspx" value="/tourBooking.aspx" />
          <add key="tourBooking.htm" value="/tourBooking.aspx" />
          <add key="TourBooking.htm" value="/tourBooking.aspx" />
        </rewriteMap>
      </rewriteMaps>

      <rules>

        <!-- Force HTTPS for public hosts only -->
        <rule name="Force HTTPS for public hosts" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^(localhost|127\.0\.0\.1|::1)(:\d+)?$" negate="true" ignoreCase="true" />
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect"
                  url="https://{HTTP_HOST}/{R:1}"
                  appendQueryString="true"
                  redirectType="Permanent" />
        </rule>

        <!-- Force non-www canonical host -->
        <rule name="Force canonical host" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^(localhost|127\.0\.0\.1|::1)(:\d+)?$" negate="true" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^www\.jaredthenyctourguide\.com$" ignoreCase="true" />
          </conditions>
          <action type="Redirect"
                  url="https://jaredthenyctourguide.com/{R:1}"
                  appendQueryString="true"
                  redirectType="Permanent" />
        </rule>

        <!-- 301 fix: Guilded -> Gilded -->
        <rule name="301 Guilded-Age-Tour.html -> Gilded-Age-Tour.html" stopProcessing="true">
          <match url="^Guilded-Age-Tour\.html$" ignoreCase="true" />
          <action type="Redirect"
                  url="/Gilded-Age-Tour.html"
                  redirectType="Permanent"
                  appendQueryString="true" />
        </rule>

        <!-- Root index -->
        <rule name="Root index to root" stopProcessing="true">
          <match url="^index\.htm$" ignoreCase="true" />
          <action type="Redirect"
                  url="/"
                  redirectType="Permanent"
                  appendQueryString="true" />
        </rule>

        <!-- Blog index -->
        <rule name="Blog index to blog root" stopProcessing="true">
          <match url="^blog/index\.htm$" ignoreCase="true" />
          <action type="Redirect"
                  url="/blog/"
                  redirectType="Permanent"
                  appendQueryString="false" />
        </rule>

        <!-- Only the legacy blog landing page -->
        <rule name="Legacy blog Default.aspx to blog root" stopProcessing="true">
          <match url="^blog/default\.aspx$" ignoreCase="true" />
          <action type="Redirect"
                  url="/blog/"
                  redirectType="Permanent"
                  appendQueryString="false" />
        </rule>

        <!-- Exact legacy URL -->
        <rule name="Legacy autism tour page" stopProcessing="true">
          <match url="^tours/autism\.htm$" ignoreCase="true" />
          <action type="Redirect"
                  url="/destinations.htm"
                  redirectType="Permanent"
                  appendQueryString="false" />
        </rule>

        <!-- Exact malformed crawler-discovered URL -->
        <rule name="Malformed John Sebastian blog URL to blog root" stopProcessing="true">
          <match url="^blog/1944John Sebastian.*$" ignoreCase="true" />
          <action type="Redirect"
                  url="/blog/"
                  redirectType="Permanent"
                  appendQueryString="false" />
        </rule>

        <!-- Dated blog URLs that were really root-page links rendered relatively -->
        <rule name="Dated blog root-page mislinks" stopProcessing="true">
          <match url="^blog/\d{4}/\d{2}/\d{2}/([^/]+)$" ignoreCase="true" />
          <conditions>
            <add input="{LegacyRootPageTargets:{R:1}}" pattern="(.+)" />
          </conditions>
          <action type="Redirect"
                  url="{C:1}"
                  redirectType="Permanent"
                  appendQueryString="false" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>